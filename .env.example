# 🌾 Petani Maju - Environment Configuration Template
# 
# Instruksi Setup:
# 1. Copy file ini dan rename menjadi ".env" (hapus ".example")
# 2. Isi nilai-nilai credential Anda di bawah
# 3. Simpan file .env (sudah di .gitignore, tidak akan ter-push ke GitHub)
# 4. Jalankan: flutter run --dart-define-from-file=.env
#
# ⚠️ PENTING: 
# - Gunakan credential DEVELOPMENT, bukan PRODUCTION
# - Jangan pernah commit file ".env" ke GitHub
# - Setiap developer perlu file .env sendiri dengan credential mereka

# ========================================
# 🔐 SUPABASE Configuration
# ========================================
# 
# Dapatkan dari: https://supabase.com → Project Settings → API
# 
# Langkah-langkah:
# 1. Login ke Supabase dashboard (https://supabase.com)
# 2. Pilih project Anda dari sidebar
# 3. Masuk ke Settings → API
# 4. Copy "Project URL" → paste ke SUPABASE_URL
# 5. Copy "anon public" key → paste ke SUPABASE_ANON_KEY
#
# Format yang benar:
# SUPABASE_URL=https://project-name.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here


# ========================================
# 🌤️ OpenWeather API Configuration
# ========================================
#
# Dapatkan dari: https://openweathermap.org → API Keys
#
# Langkah-langkah:
# 1. Buka https://openweathermap.org
# 2. Sign Up (atau Login jika sudah punya akun)
# 3. Di dashboard, pilih menu "API Keys"
# 4. Copy default API key atau buat yang baru
# 5. Paste ke OPENWEATHER_API_KEY
#
# Catatan:
# - API key gratis: 60 request/menit
# - Cocok untuk development/testing
# - Untuk production, upgrade ke paid plan untuk rate limit lebih tinggi
#
# Format yang benar:
# OPENWEATHER_API_KEY=abc123def456ghi789jkl012mno34567pqr

OPENWEATHER_API_KEY=your_openweather_api_key_here


# ========================================
# 🧠 ML Model Configuration (Optional)
# ========================================
# Untuk fitur deteksi penyakit tanaman (jika digunakan)

MODEL_TOMATO=your_model_tomato_url_here


# ========================================
# ✅ Pre-Flight Checklist
# ========================================
#
# Sebelum menjalankan app, pastikan:
# 
# 1. File ".env" sudah dibuat (di root folder, sejajar pubspec.yaml)
#    ✓ Bukan .env.example, tapi .env
#    ✓ Di folder root project
#
# 2. SUPABASE_URL sudah diisi dengan benar
#    ✓ Format: https://project-name.supabase.co
#    ✓ Bukan contoh, tapi credential asli Anda
#
# 3. SUPABASE_ANON_KEY sudah diisi
#    ✓ Panjang: minimal 200+ karakter
#    ✓ Format: dimulai dengan eyJhbGciOi...
#
# 4. OPENWEATHER_API_KEY sudah diisi
#    ✓ Panjang: 32 karakter
#    ✓ Bukan placeholder, tapi API key asli
#
# 5. Internet connection aktif
#    ✓ Verifikasi bisa akses https://supabase.com
#    ✓ Verifikasi bisa akses https://openweathermap.org
#
# ========================================
# 🚀 Cara Menjalankan
# ========================================
#
# Pilihan 1: Dengan --dart-define-from-file
# $ flutter run --dart-define-from-file=.env
#
# Pilihan 2: Tanpa flag (jika sudah dikonfigurasi di IDE)
# $ flutter run
#
# Build APK dengan credential:
# $ flutter build apk --dart-define-from-file=.env
#
# ========================================
# 🐛 Troubleshooting
# ========================================
#
# Error: "Gagal memuat data. Periksa koneksi internet..."
# → Lihat README.md → Troubleshooting section
#
# Error: "SUPABASE_URL is null"
# → Pastikan .env file ada dan terisi dengan benar
#
# Error: "Invalid API Key"
# → Copy ulang credential dari dashboard Supabase
#
# Error: "Connection timeout"
# → Verifikasi internet connection
# → Pastikan credential sudah benar
# → Cek status Supabase project (online/offline)
#
# ========================================
